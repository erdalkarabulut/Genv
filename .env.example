# GenVApi Production Environment Variables
# Copy this file to .env and fill in your values

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=gen_v_api_db

# Connection String (auto-generated from above, or set directly)
# DATABASE_URL=Host=postgres;Port=5432;Database=gen_v_api_db;Username=postgres;Password=your_secure_password_here

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# JWT Settings (if needed)
# JWT_SECRET=your_jwt_secret_key_here
# JWT_ISSUER=GenVApi
# JWT_AUDIENCE=GenVApiUsers

# Logging
# LOG_LEVEL=Information

# URL Settings
# BACKEND_URL=http://api:8080
# FRONTEND_URL=http://localhost

# ============================================
# FRONTEND (Vite)
# ============================================
VITE_API_URL=http://localhost:8080
VITE_APP_TITLE=GenVApi
